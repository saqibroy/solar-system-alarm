SHINEMONITOR_USERNAME=your_knoxhybrid_login
SHINEMONITOR_PASSWORD=your_knoxhybrid_password
SHINEMONITOR_COMPANY_KEY=obtain_from_knoxhybrid_login_capture
SHINEMONITOR_BASE_URL=http://api.shinemonitor.com/public/
SHINEMONITOR_SUFFIX_CONTEXT=&i18n=en_US&lang=en_US&source=1&_app_client_=android&_app_id_=wifiapp.volfw.watchpower&_app_version_=1.0.6.3

# Prefer setting all four values after discovery. If devcode/devaddr/sn are blank,
# the watcher tries to find a matching device from your account.
SHINEMONITOR_DATALOGGER_PN=
SHINEMONITOR_DEVICE_SN=
SHINEMONITOR_DEVICE_CODE=
SHINEMONITOR_DEVICE_ADDR=
SHINEMONITOR_PLANT_ID=

POLL_INTERVAL_SECONDS=90
STATE_FILE=/var/lib/wapda-alarm/state.json
TOKEN_REGISTRY_FILE=/var/lib/wapda-alarm/tokens.json
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8088
REGISTRATION_SECRET=change-this-long-random-string

FIREBASE_CREDENTIALS=/etc/wapda-alarm/firebase-service-account.json
FCM_DEVICE_TOKENS=
FCM_TOPIC=wapda-alarm-alerts

# Optional override. Keywords match warning desc/code/alias/status text case-insensitively.
# ALARM_DEFINITIONS_JSON=[{"name":"LINE_FAIL","keywords":["LINE_FAIL","Line Fail"],"severity":"critical"},{"name":"PV_LOSS","keywords":["PV Loss","PV_LOSS","PV input lost"],"severity":"warning"}]
